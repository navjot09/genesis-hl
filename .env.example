# =============================================================================
# Genesis — environment variable reference
# =============================================================================
# NOTHING in this file is a real secret; it documents every variable the app
# needs. Copy the relevant sections into the real (gitignored) files:
#
#   Backend  ->  functions/.env            (non-secret config, committed-safe defaults)
#            ->  functions/.secret.local   (SECRETS for the local emulator)
#            ->  Firebase Secret Manager    (SECRETS in production, via
#                                            `firebase functions:secrets:set NAME`)
#
#   Frontend ->  frontend/.env.local       (all VITE_* vars; safe to expose to the browser)
# =============================================================================


# -----------------------------------------------------------------------------
# BACKEND — functions/.env  (non-secret configuration)
# -----------------------------------------------------------------------------

# Which LLM provider adapter to use: gemini | claude | openai
LLM_PROVIDER=gemini

# Gemini model IDs (see https://ai.google.dev/gemini-api/docs/models)
GEMINI_MODEL=gemini-flash-latest
GEMINI_MODEL_HEAVY=gemini-pro-latest

# HighLevel marketplace app (Client ID is not secret; Client Secret IS — see below)
HL_CLIENT_ID=your-highlevel-client-id

# The EXACT OAuth redirect URI registered in your HighLevel marketplace app.
# Emulator:  http://127.0.0.1:5001/demo-genesis/us-central1/oauthCallback
# Production: https://us-central1-<your-project>.cloudfunctions.net/oauthCallback
HL_REDIRECT_URI=http://127.0.0.1:5001/demo-genesis/us-central1/oauthCallback

# Space-separated OAuth scopes to request. Only request scopes ENABLED on your HL app.
HL_SCOPES=contacts.readonly contacts.write conversations.readonly conversations/message.readonly conversations/message.write calendars.readonly calendars/events.readonly

# HighLevel hosts (defaults shown). Point BOTH at scripts/mock-hl.mjs (http://127.0.0.1:8788)
# to exercise the OAuth + proxy flow offline.
HL_API_BASE=https://services.leadconnectorhq.com
HL_AUTHORIZE_BASE=https://marketplace.leadconnectorhq.com

# Where to send the user back to in the SPA after the OAuth round-trip completes.
# Also used as the allowed CORS origin for the API/SSE endpoints.
APP_BASE_URL=http://localhost:5173

# Firebase project id (for the Admin SDK in production; the emulator injects its own)
GCLOUD_PROJECT=demo-genesis


# -----------------------------------------------------------------------------
# BACKEND SECRETS — functions/.secret.local (emulator) / Secret Manager (prod)
# -----------------------------------------------------------------------------

# Google Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# HighLevel marketplace app Client Secret (Developer Portal -> App -> Advanced -> Auth)
HL_CLIENT_SECRET=your-highlevel-client-secret

# HS256 signing secret for short-lived "preview capability" tokens handed to the
# generated app's iframe. Generate a long random string, e.g. `openssl rand -hex 32`.
PREVIEW_TOKEN_SECRET=change-me-to-a-long-random-string


# -----------------------------------------------------------------------------
# FRONTEND — frontend/.env.local  (VITE_* — exposed to the browser, non-secret)
# -----------------------------------------------------------------------------

# Firebase web app config (Project settings -> Your apps -> Web app).
# For emulator-only development these can be any non-empty placeholder values.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-genesis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-genesis
VITE_FIREBASE_STORAGE_BUCKET=demo-genesis.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Direct base URL of the Cloud Functions (SSE must NOT go through Hosting rewrites).
# Emulator:  http://127.0.0.1:5001/demo-genesis/us-central1
# Production: https://us-central1-<your-project>.cloudfunctions.net
VITE_FUNCTIONS_BASE_URL=http://127.0.0.1:5001/demo-genesis/us-central1

# Point the Firebase JS SDK at the local emulator suite (true in dev, false/unset in prod)
VITE_USE_EMULATORS=true
