{
  "name": "genesis",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered HighLevel app builder (root workspace)",
  "scripts": {
    "emulators": "firebase emulators:start",
    "emulators:persist": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:functions": "npm --prefix functions run build",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:functions && npm run build:frontend",
    "deploy": "npm run build && firebase deploy"
  },
  "devDependencies": {
    "firebase-tools": "^15.23.0"
  }
}
